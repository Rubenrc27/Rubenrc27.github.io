---
import { getLangFromUrl, useTranslations } from '../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const systems = [
	{ icon: "🖥️", name: t('systems.term.name'), desc: t('systems.term.desc') },
	{ icon: "⚙️", name: t('systems.webmin.name'), desc: t('systems.webmin.desc') },
	{ icon: "🔌", name: t('systems.networks.name'), desc: t('systems.networks.desc') },
	{ icon: "🔧", name: t('systems.hardware.name'), desc: t('systems.hardware.desc') }
];
---
<section id="sistemas" class="s-alt">
	<div class="container">
		<span class="s-label">{t('systems.label')}</span>
		<h2 class="s-title">{t('systems.title')}</h2>
		<div class="sys-grid">
			{systems.map(sys => (
				<div class="sys-card">
					<div class="sys-icon">{sys.icon}</div>
					<h3 class="sys-name">{sys.name}</h3>
					<p class="sys-desc">{sys.desc}</p>
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.s-alt {
		background: var(--surface);
	}
	.sys-grid {
		display: grid;
		grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
		gap: 2rem;
	}
	.sys-card {
		background: var(--card);
		border: 1px solid var(--border);
		padding: 2rem;
		border-radius: 12px;
		transition: all 0.3s ease;
	}
	.sys-card:hover {
		border-color: var(--accent-3);
		transform: translateY(-5px);
	}
	.sys-icon {
		font-size: 2rem;
		margin-bottom: 1rem;
	}
	.sys-name {
		font-size: 1.1rem;
		font-weight: 700;
		margin-bottom: 0.75rem;
	}
	.sys-desc {
		font-family: var(--font-mono);
		font-size: 0.8rem;
		color: var(--muted);
		line-height: 1.6;
	}
</style>
